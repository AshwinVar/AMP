# Copy this file to .env and fill in your values

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/flowmes_db

# JWT secret — generate with: openssl rand -hex 32
SECRET_KEY=replace_with_a_long_random_string

# CORS — comma-separated list of allowed frontend origins
# For Vercel deployments add your domain here
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# MQTT broker (leave default for local broker; use cloud broker host for production)
MQTT_BROKER=127.0.0.1
MQTT_PORT=1883
MQTT_TOPIC=flowmes/machines
